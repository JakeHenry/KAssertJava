{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Maven: Clean Verify",
      "type": "shell",
      "command": "cls && ${workspaceFolder}/mvnw.cmd clean verify",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "Maven: Clean Test",
      "type": "shell",
      "command": "cls && ${workspaceFolder}/mvnw.cmd clean test",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "Maven: Clean Package",
      "type": "shell",
      "command": "cls && ${workspaceFolder}/mvnw.cmd clean package",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": []
    }
  ]
}