{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Maven: Clean Verify",
      "type": "shell",
      "command": "cls && D:/apache-maven-3.2.5/bin/mvn.bat clean verify",
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "JAVA_HOME": "C:/Program Files/Java/jdk8u492-b09",
          "JAVA6_HOME": "C:/Program Files/Java/jdk1.6.0_45",
          "MAVEN_HOME": "D:/apache-maven-3.2.5"
        }
      },
      "group": "build",
      "problemMatcher": [
        "$javac"
      ]
    },
    {
      "label": "Maven: Clean Test",
      "type": "shell",
      "command": "cls && D:/apache-maven-3.2.5/bin/mvn.bat clean test",
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "JAVA_HOME": "C:/Program Files/Java/jdk8u492-b09",
          "JAVA6_HOME": "C:/Program Files/Java/jdk1.6.0_45",
          "MAVEN_HOME": "D:/apache-maven-3.2.5"
        }
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": []
    },
    {
      "label": "Maven: Clean Package",
      "type": "shell",
      "command": "cls && D:/apache-maven-3.2.5/bin/mvn.bat clean package",
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "JAVA_HOME": "C:/Program Files/Java/jdk8u492-b09",
          "JAVA6_HOME": "C:/Program Files/Java/jdk1.6.0_45",
          "MAVEN_HOME": "D:/apache-maven-3.2.5"
        }
